{
  "name": "driftlens",
  "version": "0.2.0",
  "description": "The observability platform for AI-assisted development. Proves ROI in dollars. Predicts failures. Routes to the best agent.",
  "type": "module",
  "bin": {
    "driftlens": "./dist/cli/index.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding",
    "agent",
    "skill",
    "copilot",
    "claude",
    "cursor",
    "drift",
    "correction",
    "observability",
    "productivity",
    "roi",
    "mcp",
    "prevention",
    "quality",
    "maturity",
    "regression",
    "intelligence"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "hooks/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@fastify/static": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^20.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fastify": "^4.28.0",
    "open": "^11.0.0",
    "simple-git": "^3.25.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.3.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
